FROM node:20-bullseye

WORKDIR /app

RUN apt-get update && apt-get install -y \
  build-essential \
  cairo2-dev \
  libpango1.0-dev \
  libjpeg62-turbo-dev \
  libgif-dev \
  librsvg2-dev \
  pixman-1-dev \
  pkg-config \
  python3 \
  && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm install

COPY . .

ENV NODE_ENV=production
ENV PORT=3000

EXPOSE 3000

CMD ["npm", "start"]
